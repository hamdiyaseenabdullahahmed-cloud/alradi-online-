<%# ============================================= %>
<%# متجر الرعدي أون لاين - alradi-online          %>
<%# صفحة الخطأ                                      %>
<%# ============================================= %>

<%- include('partials/header') %>

<div class="container">
    <div style="text-align: center; padding: 80px 20px; max-width: 600px; margin: 0 auto;">
        
        <div style="font-size: 100px; color: var(--danger-color); margin-bottom: 20px;">
            <i class="fas fa-exclamation-triangle"></i>
        </div>
        
        <h1 style="font-size: 32px; font-weight: 900; color: var(--primary-color); margin-bottom: 15px;">
            <%= typeof statusCode !== 'undefined' ? statusCode : '500' %> - 
            <%= currentLanguage === 'en' ? 'Error' : 'حدث خطأ' %>
        </h1>
        
        <p style="color: var(--text-muted); font-size: 16px; margin-bottom: 30px; line-height: 1.8;">
            <% if (typeof error !== 'undefined' && error.message) { %>
                <%= error.message %>
            <% } else { %>
                <%= currentLanguage === 'en' ? 'An unexpected error occurred. Please try again later.' : 'نعتذر، حدث خطأ غير متوقع أثناء معالجة طلبك. يرجى المحاولة مرة أخرى.' %>
            <% } %>
        </p>
        
        <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
            <a href="/" class="btn btn-primary btn-lg">
                <i class="fas fa-home"></i> <%= currentLanguage === 'en' ? 'Go Home' : 'العودة للرئيسية' %>
            </a>
            <a href="javascript:location.reload()" class="btn btn-outline btn-lg">
                <i class="fas fa-redo"></i> <%= currentLanguage === 'en' ? 'Try Again' : 'تحديث الصفحة' %>
            </a>
            <a href="/contact" class="btn btn-outline btn-lg">
                <i class="fas fa-envelope"></i> <%= currentLanguage === 'en' ? 'Contact Us' : 'اتصل بنا' %>
            </a>
        </div>
        
        <% if (typeof error !== 'undefined' && error.stack) { %>
            <div style="margin-top: 40px; text-align: left; background: var(--bg-color); padding: 20px; border-radius: 10px; overflow-x: auto; display: none;">
                <pre style="font-size: 11px; color: var(--text-muted); white-space: pre-wrap; word-break: break-all;"><%= error.stack %></pre>
            </div>
        <% } %>
    </div>
</div>

<%- include('partials/footer') %>
