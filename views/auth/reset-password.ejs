<%# ============================================= %>
<%# متجر الرعدي أون لاين - alradi-online          %>
<%# صفحة إعادة تعيين كلمة المرور                    %>
<%# ============================================= %>

<%- include('../partials/header') %>

<div class="container">
    <div style="max-width: 450px; margin: 40px auto;">
        
        <%# ============================================= %>
        <%# أيقونة المفتاح                                  %>
        <%# ============================================= %>
        <div style="text-align: center; margin-bottom: 30px;">
            <div style="display: inline-block; width: 90px; height: 90px; background: linear-gradient(135deg, var(--success-color), #1e7e34); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 15px; box-shadow: 0 5px 20px rgba(40,167,69,0.3);">
                <i class="fas fa-key" style="font-size: 40px; color: white;"></i>
            </div>
            <h2 style="font-size: 26px; font-weight: 900; color: var(--primary-color); margin-bottom: 5px;">
                <%= currentLanguage === 'en' ? 'Set New Password' : 'تعيين كلمة مرور جديدة' %>
            </h2>
            <p style="color: var(--text-muted); font-size: 14px; padding: 0 20px;">
                <%= currentLanguage === 'en' ? 'Enter your new password below. Choose a strong password to protect your account.' : 'أدخل كلمة المرور الجديدة أدناه. اختر كلمة مرور قوية لحماية حسابك.' %>
            </p>
        </div>
        
        <%# ============================================= %>
        <%# نموذج كلمة المرور الجديدة                        %>
        <%# ============================================= %>
        <div style="background: white; border-radius: 20px; padding: 35px; box-shadow: 0 5px 25px rgba(0,0,0,0.1);">
            <form action="/auth/reset-password" method="POST" data-validate>
                
                <%# كلمة المرور الجديدة %>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-lock" style="color: var(--success-color); margin-left: 5px;"></i>
                        <%= currentLanguage === 'en' ? 'New Password' : 'كلمة المرور الجديدة' %> *
                    </label>
                    <div style="position: relative;">
                        <input type="password" 
                               name="password" 
                               class="form-control" 
                               id="newPassword"
                               placeholder="<%= currentLanguage === 'en' ? 'At least 6 characters' : '6 أحرف على الأقل' %>" 
                               minlength="6" 
                               required
                               autofocus>
                        <button type="button" 
                                onclick="togglePasswordVisibility('newPassword', this)" 
                                style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: var(--text-muted); font-size: 18px;"
                                aria-label="إظهار كلمة المرور">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    
                    <%# مؤشر قوة كلمة المرور %>
                    <div style="margin-top: 10px;">
                        <div style="display: flex; gap: 5px;" id="passwordStrengthBar">
                            <div style="flex: 1; height: 4px; background: var(--border-color); border-radius: 2px; transition: all 0.3s;"></div>
                            <div style="flex: 1; height: 4px; background: var(--border-color); border-radius: 2px; transition: all 0.3s;"></div>
                            <div style="flex: 1; height: 4px; background: var(--border-color); border-radius: 2px; transition: all 0.3s;"></div>
                            <div style="flex: 1; height: 4px; background: var(--border-color); border-radius: 2px; transition: all 0.3s;"></div>
                        </div>
                        <small id="passwordStrengthText" style="color: var(--text-muted); display: block; margin-top: 5px; font-size: 12px;">
                            <%= currentLanguage === 'en' ? 'Enter your new password' : 'أدخل كلمة المرور الجديدة' %>
                        </small>
                    </div>
                </div>
                
                <%# تأكيد كلمة المرور %>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-check-circle" style="color: var(--success-color); margin-left: 5px;"></i>
                        <%= currentLanguage === 'en' ? 'Confirm New Password' : 'تأكيد كلمة المرور الجديدة' %> *
                    </label>
                    <input type="password" 
                           name="password2" 
                           class="form-control" 
                           id="confirmPassword"
                           placeholder="<%= currentLanguage === 'en' ? 'Re-enter new password' : 'أعد إدخال كلمة المرور الجديدة' %>" 
                           required>
                    <small id="passwordMatchText" style="display: none; margin-top: 5px; font-size: 12px;"></small>
                </div>
                
                <%# نصائح كلمة المرور القوية %>
                <div style="margin-bottom: 20px; padding: 12px; background: var(--bg-color); border-radius: 8px; font-size: 12px; color: var(--text-light);">
                    <p style="margin: 0 0 5px 0; font-weight: bold;">
                        <i class="fas fa-shield-alt"></i> 
                        <%= currentLanguage === 'en' ? 'Strong password tips' : 'نصائح لكلمة مرور قوية' %>
                    </p>
                    <ul style="margin: 0; padding-right: 18px; line-height: 1.8;">
                        <li><%= currentLanguage === 'en' ? 'Use at least 8 characters' : 'استخدم 8 أحرف على الأقل' %></li>
                        <li><%= currentLanguage === 'en' ? 'Mix uppercase and lowercase letters' : 'امزج بين الأحرف الكبيرة والصغيرة' %></li>
                        <li><%= currentLanguage === 'en' ? 'Include numbers and symbols' : 'أضف أرقاماً ورموزاً' %></li>
                        <li><%= currentLanguage === 'en' ? 'Avoid common words and personal info' : 'تجنب الكلمات الشائعة والمعلومات الشخصية' %></li>
                    </ul>
                </div>
                
                <%# زر حفظ كلمة المرور %>
                <button type="submit" class="btn btn-success btn-block btn-lg" id="submitBtn">
                    <i class="fas fa-save"></i> 
                    <%= currentLanguage === 'en' ? 'Save New Password' : 'حفظ كلمة المرور الجديدة' %>
                </button>
                
                <%# روابط سفلية %>
                <div style="text-align: center; margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--border-color);">
                    <p style="font-size: 14px; color: var(--text-muted); margin-bottom: 0;">
                        <%= currentLanguage === 'en' ? 'Remember your password?' : 'تذكرت كلمة المرور؟' %>
                        <a href="/auth/login" style="color: var(--secondary-color); font-weight: bold; text-decoration: none;">
                            <i class="fas fa-sign-in-alt"></i> 
                            <%= currentLanguage === 'en' ? 'Login' : 'تسجيل الدخول' %>
                        </a>
                    </p>
                </div>
            </form>
        </div>
        
        <%# ============================================= %>
        <%# تنبيه أمني                                      %>
        <%# ============================================= %>
        <div style="margin-top: 20px; padding: 15px; background: var(--danger-bg); border-radius: 12px; font-size: 13px; color: #721c24; border-right: 4px solid var(--danger-color);">
            <p style="margin: 0; font-weight: bold;">
                <i class="fas fa-exclamation-triangle"></i> 
                <%= currentLanguage === 'en' ? 'Important' : 'مهم' %>
            </p>
            <p style="margin: 5px 0 0 0; font-size: 12px;">
                <%= currentLanguage === 'en' ? 'After changing your password, you will need to login again on all your devices.' : 'بعد تغيير كلمة المرور، ستحتاج إلى تسجيل الدخول مرة أخرى على جميع أجهزتك.' %>
            </p>
        </div>
        
        <%# رابط العودة %>
        <div style="text-align: center; margin-top: 20px;">
            <a href="/" style="font-size: 14px; color: var(--text-muted); text-decoration: none;">
                <i class="fas fa-arrow-right"></i> 
                <%= currentLanguage === 'en' ? 'Back to Home' : 'العودة للرئيسية' %>
            </a>
        </div>
    </div>
</div>

<script>
function togglePasswordVisibility(inputId, btn) {
    const input = document.getElementById(inputId);
    const icon = btn.querySelector('i');
    if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'fas fa-eye-slash';
    } else {
        input.type = 'password';
        icon.className = 'fas fa-eye';
    }
}

// مؤشر قوة كلمة المرور
document.getElementById('newPassword').addEventListener('input', function() {
    const password = this.value;
    const bars = document.querySelectorAll('#passwordStrengthBar div');
    const strengthText = document.getElementById('passwordStrengthText');
    
    let strength = 0;
    
    if (password.length >= 6) strength++;
    if (password.length >= 8) strength++;
    if (/[A-Z]/.test(password) && /[a-z]/.test(password)) strength++;
    if (/[0-9]/.test(password)) strength++;
    if (/[^A-Za-z0-9]/.test(password)) strength++;
    
    const colors = ['#dc3545', '#ffc107', '#fd7e14', '#28a745', '#20c997'];
    const texts = [
        '<%= currentLanguage === "en" ? "Very weak" : "ضعيفة جداً" %>',
        '<%= currentLanguage === "en" ? "Weak" : "ضعيفة" %>',
        '<%= currentLanguage === "en" ? "Medium" : "متوسطة" %>',
        '<%= currentLanguage === "en" ? "Strong" : "قوية" %>',
        '<%= currentLanguage === "en" ? "Very strong" : "قوية جداً" %>'
    ];
    
    const level = Math.min(strength, 5);
    
    bars.forEach((bar, index) => {
        if (index < level) {
            bar.style.background = colors[level - 1];
        } else {
            bar.style.background = 'var(--border-color)';
        }
    });
    
    if (password.length === 0) {
        strengthText.textContent = '<%= currentLanguage === "en" ? "Enter your new password" : "أدخل كلمة المرور الجديدة" %>';
        strengthText.style.color = 'var(--text-muted)';
    } else {
        strengthText.textContent = texts[level - 1] || texts[0];
        strengthText.style.color = colors[level - 1] || colors[0];
    }
});

// التحقق من تطابق كلمة المرور
document.getElementById('confirmPassword').addEventListener('input', function() {
    const password = document.getElementById('newPassword').value;
    const matchText = document.getElementById('passwordMatchText');
    
    if (this.value.length === 0) {
        matchText.style.display = 'none';
    } else if (password === this.value) {
        matchText.style.display = 'block';
        matchText.textContent = '✅ <%= currentLanguage === "en" ? "Passwords match" : "كلمات المرور متطابقة" %>';
        matchText.style.color = 'var(--success-color)';
    } else {
        matchText.style.display = 'block';
        matchText.textContent = '❌ <%= currentLanguage === "en" ? "Passwords do not match" : "كلمات المرور غير متطابقة" %>';
        matchText.style.color = 'var(--danger-color)';
    }
});

// منع الإرسال إذا كانت الكلمات غير متطابقة
document.querySelector('form').addEventListener('submit', function(e) {
    const password = document.getElementById('newPassword').value;
    const password2 = document.getElementById('confirmPassword').value;
    
    if (password !== password2) {
        e.preventDefault();
        alert('<%= currentLanguage === "en" ? "Passwords do not match!" : "كلمات المرور غير متطابقة!" %>');
        return false;
    }
    
    if (password.length < 6) {
        e.preventDefault();
        alert('<%= currentLanguage === "en" ? "Password must be at least 6 characters!" : "كلمة المرور يجب أن تكون 6 أحرف على الأقل!" %>');
        return false;
    }
});
</script>

<%- include('../partials/footer') %>
