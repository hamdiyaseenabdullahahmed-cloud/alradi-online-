<%# ============================================= %>
<%# متجر الرعدي أون لاين - alradi-online          %>
<%# صفحة استعادة كلمة المرور                        %>
<%# ============================================= %>

<%- include('../partials/header') %>

<div class="container">
    <div style="max-width: 450px; margin: 40px auto;">
        
        <%# ============================================= %>
        <%# أيقونة القفل                                    %>
        <%# ============================================= %>
        <div style="text-align: center; margin-bottom: 30px;">
            <div style="display: inline-block; width: 90px; height: 90px; background: linear-gradient(135deg, var(--primary-color), var(--accent-color)); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 15px; box-shadow: 0 5px 20px rgba(26,26,46,0.3);">
                <i class="fas fa-lock-open" style="font-size: 40px; color: var(--gold-color);"></i>
            </div>
            <h2 style="font-size: 26px; font-weight: 900; color: var(--primary-color); margin-bottom: 5px;">
                <%= currentLanguage === 'en' ? 'Forgot Password?' : 'نسيت كلمة المرور؟' %>
            </h2>
            <p style="color: var(--text-muted); font-size: 14px; padding: 0 20px;">
                <%= currentLanguage === 'en' ? 'Don\'t worry! Enter your registered email and we\'ll send you a verification code to reset your password.' : 'لا تقلق! أدخل بريدك الإلكتروني المسجل وسنرسل لك رمز تحقق لإعادة تعيين كلمة المرور.' %>
            </p>
        </div>
        
        <%# ============================================= %>
        <%# نموذج استعادة كلمة المرور                        %>
        <%# ============================================= %>
        <div style="background: white; border-radius: 20px; padding: 35px; box-shadow: 0 5px 25px rgba(0,0,0,0.1);">
            <form action="/auth/forgot-password" method="POST">
                
                <%# حقل البريد الإلكتروني %>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-envelope" style="color: var(--secondary-color); margin-left: 5px;"></i>
                        <%= currentLanguage === 'en' ? 'Email Address' : 'البريد الإلكتروني' %> *
                    </label>
                    <input type="email" 
                           name="email" 
                           class="form-control" 
                           placeholder="example@email.com" 
                           required 
                           autofocus
                           autocomplete="email">
                    <small style="color: var(--text-muted); display: block; margin-top: 5px;">
                        <i class="fas fa-info-circle"></i> 
                        <%= currentLanguage === 'en' ? 'Enter the email you used when creating your account' : 'أدخل البريد الإلكتروني الذي استخدمته عند إنشاء حسابك' %>
                    </small>
                </div>
                
                <%# زر إرسال رمز التحقق %>
                <button type="submit" class="btn btn-primary btn-block btn-lg">
                    <i class="fas fa-paper-plane"></i> 
                    <%= currentLanguage === 'en' ? 'Send Verification Code' : 'إرسال رمز التحقق' %>
                </button>
                
                <%# معلومات إضافية %>
                <div style="margin-top: 20px; padding: 15px; background: var(--warning-bg); border-radius: 10px; font-size: 13px; color: #856404; border-right: 4px solid var(--warning-color);">
                    <p style="margin: 0;">
                        <i class="fas fa-info-circle"></i> 
                        <%= currentLanguage === 'en' ? 'For security reasons, the verification code will expire after 10 minutes.' : 'لأسباب أمنية، سينتهي صلاحية رمز التحقق بعد 10 دقائق.' %>
                    </p>
                    <p style="margin: 5px 0 0 0;">
                        <i class="fas fa-shield-alt"></i> 
                        <%= currentLanguage === 'en' ? 'Check your spam folder if you don\'t receive the email.' : 'تأكد من صندوق البريد المزعج (Spam) إذا لم تستلم البريد.' %>
                    </p>
                </div>
            </form>
            
            <%# ============================================= %>
            <%# روابط سفلية                                    %>
            <%# ============================================= %>
            <div style="text-align: center; margin-top: 25px; padding-top: 20px; border-top: 1px solid var(--border-color);">
                <p style="font-size: 14px; color: var(--text-muted); margin-bottom: 10px;">
                    <%= currentLanguage === 'en' ? 'Remember your password?' : 'تذكرت كلمة المرور؟' %>
                    <a href="/auth/login" style="color: var(--secondary-color); font-weight: bold; text-decoration: none;">
                        <i class="fas fa-sign-in-alt"></i> 
                        <%= currentLanguage === 'en' ? 'Back to Login' : 'العودة لتسجيل الدخول' %>
                    </a>
                </p>
                <p style="font-size: 14px; color: var(--text-muted); margin-bottom: 0;">
                    <%= currentLanguage === 'en' ? 'Don\'t have an account?' : 'ليس لديك حساب؟' %>
                    <a href="/auth/register" style="color: var(--secondary-color); font-weight: bold; text-decoration: none;">
                        <i class="fas fa-user-plus"></i> 
                        <%= currentLanguage === 'en' ? 'Create New Account' : 'إنشاء حساب جديد' %>
                    </a>
                </p>
            </div>
        </div>
        
        <%# ============================================= %>
        <%# خطوات استعادة كلمة المرور                       %>
        <%# ============================================= %>
        <div style="margin-top: 30px;">
            <h4 style="text-align: center; font-size: 16px; font-weight: 700; color: var(--primary-color); margin-bottom: 20px;">
                <i class="fas fa-list-ol" style="color: var(--secondary-color); margin-left: 5px;"></i>
                <%= currentLanguage === 'en' ? 'Password Recovery Steps' : 'خطوات استعادة كلمة المرور' %>
            </h4>
            <div style="display: flex; justify-content: space-between; position: relative; padding: 0 20px;">
                <%# خط متصل %>
                <div style="position: absolute; top: 25px; right: 60px; left: 60px; height: 2px; background: var(--border-color); z-index: 0;"></div>
                
                <%# الخطوة 1 %>
                <div style="text-align: center; position: relative; z-index: 1;">
                    <div style="width: 50px; height: 50px; background: var(--secondary-color); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 8px; color: white; font-weight: bold; font-size: 20px; box-shadow: 0 3px 10px rgba(233,69,96,0.3);">1</div>
                    <p style="font-size: 11px; font-weight: bold; color: var(--secondary-color); margin: 0;">أدخل البريد</p>
                </div>
                
                <%# الخطوة 2 %>
                <div style="text-align: center; position: relative; z-index: 1;">
                    <div style="width: 50px; height: 50px; background: var(--info-color); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 8px; color: white; font-weight: bold; font-size: 20px; box-shadow: 0 3px 10px rgba(23,162,184,0.3);">2</div>
                    <p style="font-size: 11px; font-weight: bold; color: var(--info-color); margin: 0;">أدخل الرمز</p>
                </div>
                
                <%# الخطوة 3 %>
                <div style="text-align: center; position: relative; z-index: 1;">
                    <div style="width: 50px; height: 50px; background: var(--success-color); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 8px; color: white; font-weight: bold; font-size: 20px; box-shadow: 0 3px 10px rgba(40,167,69,0.3);">3</div>
                    <p style="font-size: 11px; font-weight: bold; color: var(--success-color); margin: 0;">كلمة جديدة</p>
                </div>
            </div>
        </div>
        
        <%# رابط العودة %>
        <div style="text-align: center; margin-top: 25px;">
            <a href="/" style="font-size: 14px; color: var(--text-muted); text-decoration: none;">
                <i class="fas fa-arrow-right"></i> 
                <%= currentLanguage === 'en' ? 'Back to Home' : 'العودة للرئيسية' %>
            </a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
