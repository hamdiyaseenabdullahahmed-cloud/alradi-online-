<%# ============================================= %>
<%# متجر الرعدي أون لاين - alradi-online          %>
<%# ترويسة الموقع                                  %>
<%# ============================================= %>

<!DOCTYPE html>
<html dir="<%= currentLanguage === 'en' ? 'ltr' : 'rtl' %>" lang="<%= currentLanguage || 'ar' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= store.storeDescription || 'متجر إلكتروني متكامل للتسوق العالمي' %>">
    <meta name="keywords" content="متجر, الرعدي, تسوق, إلكتروني, أون لاين">
    <meta name="author" content="متجر الرعدي أون لاين">
    <meta name="theme-color" content="#1a1a2e">
    
    <link rel="icon" type="image/png" href="<%= store.storeFavicon || store.storeLogo || 'data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🦅</text></svg>' %>">
    <link rel="apple-touch-icon" href="<%= store.storeLogo || 'data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🦅</text></svg>' %>">
    
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' | ' : '' %><%= store.storeName || 'متجر الرعدي أون لاين' %></title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800;900&family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link rel="stylesheet" href="/css/style.css">
    
    <script>
        if (document.cookie.includes('darkMode=true')) {
            document.documentElement.classList.add('dark-mode');
        }
    </script>
</head>
<body class="<%= currentLanguage === 'en' ? 'en' : '' %>">

    <%# شريط الإعلانات الترويجي %>
    <% if (store.showPromoBanner !== false) { %>
    <div class="promo-banner" id="promoBanner">
        <span>
            <i class="fas fa-truck"></i>
            <%= currentLanguage === 'en' ? (store.promoBannerTextEn || '🚀 Free shipping for orders over 300 SAR | 15% off first order') : (store.promoBannerText || '🚀 شحن مجاني للطلبات فوق 300 ريال | خصم 15% على أول طلب') %>
        </span>
        <button class="close-banner" onclick="document.getElementById('promoBanner').style.display='none'" aria-label="إغلاق">
            <i class="fas fa-times"></i>
        </button>
    </div>
    <% } %>

    <%# الهيدر الرئيسي %>
    <header class="main-header" id="mainHeader">
        <div class="container">
            <div class="header-content">
                
                <button class="mobile-menu-toggle" aria-label="القائمة">
                    <i class="fas fa-bars"></i>
                </button>
                
                <div class="logo-container">
                    <a href="/" class="logo-link" title="<%= store.storeName || 'متجر الرعدي أون لاين' %>">
                        <% if (store.storeLogo) { %>
                            <img src="<%= store.storeLogo %>" 
                                 alt="<%= store.storeName %>" 
                                 class="store-logo"
                                 width="55" height="55"
                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                        <% } %>
                        <div class="store-logo-placeholder" style="<%= store.storeLogo ? 'display:none;' : '' %>width:55px;height:55px;border-radius:50%;background:linear-gradient(135deg,var(--gold-color),#ff6b6b);display:flex;align-items:center;justify-content:center;font-size:30px;border:2px solid var(--gold-color);">
                            🦅
                        </div>
                        <span class="store-name"><%= store.storeName || 'متجر الرعدي أون لاين' %></span>
                    </a>
                </div>
                
                <div class="search-container">
                    <form class="search-bar" action="/search" method="GET">
                        <input type="text" 
                               name="q" 
                               placeholder="<%= currentLanguage === 'en' ? 'Search for products...' : 'ابحث عن المنتجات...' %>"
                               value="<%= typeof query !== 'undefined' ? query : '' %>"
                               aria-label="البحث">
                        <button type="submit" aria-label="بحث">
                            <i class="fas fa-search"></i>
                            <span class="search-text"><%= currentLanguage === 'en' ? 'Search' : 'بحث' %></span>
                        </button>
                    </form>
                </div>
                
                <div class="header-actions">
                    
                    <a href="/switch-language/<%= currentLanguage === 'ar' ? 'en' : 'ar' %>" 
                       class="header-icon" 
                       title="<%= currentLanguage === 'ar' ? 'English' : 'العربية' %>"
                       id="language-switcher">
                        <i class="fas fa-language"></i>
                        <span style="font-size: 10px; font-weight: bold;">
                            <%= currentLanguage === 'ar' ? 'EN' : 'عربي' %>
                        </span>
                    </a>
                    
                    <button class="header-icon" id="dark-mode-toggle" title="الوضع الليلي">
                        <i class="fas fa-moon"></i>
                    </button>
                    
                    <% if (user) { %>
                    <a href="/account/wishlist" class="header-icon" title="المفضلة">
                        <i class="fas fa-heart"></i>
                    </a>
                    <% } %>
                    
                    <a href="/cart" class="header-icon cart-icon" title="سلة التسوق">
                        <i class="fas fa-shopping-cart"></i>
                        <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
                            <span class="badge-count cart-count-badge"><%= cartCount %></span>
                        <% } %>
                    </a>
                    
                    <% if (user) { %>
                        <div class="user-menu">
                            <a href="/account" class="header-icon" title="حسابي">
                                <% if (user.profileImage) { %>
                                    <img src="<%= user.profileImage %>" 
                                         alt="<%= user.name %>"
                                         style="width: 35px; height: 35px; border-radius: 50%; object-fit: cover; border: 2px solid var(--gold-color);"
                                         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                <% } %>
                                <div style="<%= user.profileImage ? 'display:none;' : '' %>width:35px;height:35px;border-radius:50%;background:var(--secondary-color);color:white;display:flex;align-items:center;justify-content:center;font-weight:bold;font-size:16px;border:2px solid var(--gold-color);">
                                    <%= user.name.charAt(0) %>
                                </div>
                            </a>
                        </div>
                    <% } else { %>
                        <a href="/auth/login" class="login-btn">
                            <i class="fas fa-user"></i>
                            <span><%= currentLanguage === 'en' ? 'Login' : 'تسجيل الدخول' %></span>
                        </a>
                    <% } %>
                </div>
            </div>
            
            <nav class="main-nav" id="mainNav">
                <ul>
                    <li><a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">
                        <i class="fas fa-home"></i> <%= currentLanguage === 'en' ? 'Home' : 'الرئيسية' %>
                    </a></li>
                    <li><a href="/products" class="<%= currentPath.startsWith('/products') ? 'active' : '' %>">
                        <i class="fas fa-th-large"></i> <%= currentLanguage === 'en' ? 'All Products' : 'كل المنتجات' %>
                    </a></li>
                    <li><a href="/offers" class="<%= currentPath === '/offers' ? 'active' : '' %>">
                        <i class="fas fa-tags" style="color: var(--gold-color);"></i> <%= currentLanguage === 'en' ? 'Offers' : 'العروض' %>
                    </a></li>
                    <li><a href="/contact">
                        <i class="fas fa-envelope"></i> <%= currentLanguage === 'en' ? 'Contact Us' : 'اتصل بنا' %>
                    </a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main class="main-content">
        
        <% if (success_msg && success_msg.length > 0) { %>
            <div class="container">
                <div class="alert alert-success animate-fadeIn">
                    <i class="fas fa-check-circle"></i>
                    <span><%= Array.isArray(success_msg) ? success_msg.join(', ') : success_msg %></span>
                    <button class="alert-close" onclick="this.parentElement.remove()">&times;</button>
                </div>
            </div>
        <% } %>
        
        <% if (error_msg && error_msg.length > 0) { %>
            <div class="container">
                <div class="alert alert-danger animate-fadeIn">
                    <i class="fas fa-exclamation-circle"></i>
                    <span><%= Array.isArray(error_msg) ? error_msg.join(', ') : error_msg %></span>
                    <button class="alert-close" onclick="this.parentElement.remove()">&times;</button>
                </div>
            </div>
        <% } %>
        
        <% if (info_msg && info_msg.length > 0) { %>
            <div class="container">
                <div class="alert alert-info animate-fadeIn">
                    <i class="fas fa-info-circle"></i>
                    <span><%= Array.isArray(info_msg) ? info_msg.join(', ') : info_msg %></span>
                    <button class="alert-close" onclick="this.parentElement.remove()">&times;</button>
                </div>
            </div>
        <% } %>
