<%# ============================================= %>
<%# متجر الرعدي أون لاين - alradi-online          %>
<%# ترويسة الموقع                                  %>
<%# ============================================= %>

<!DOCTYPE html>
<html dir="<%= currentLanguage === 'en' ? 'ltr' : 'rtl' %>" lang="<%= currentLanguage || 'ar' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= store.storeDescription || 'متجر إلكتروني متكامل للتسوق العالمي' %>">
    <meta name="keywords" content="متجر, الرعدي, تسوق, إلكتروني, أون لاين">
    <meta name="author" content="متجر الرعدي أون لاين">
    <meta name="theme-color" content="#1a1a2e">
    
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🦅</text></svg>">
    
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' | ' : '' %><%= store.storeName || 'متجر الرعدي أون لاين' %></title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800;900&family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link rel="stylesheet" href="/css/style.css">
    
    <script>
        if (document.cookie.includes('darkMode=true')) {
            document.documentElement.classList.add('dark-mode');
        }
    </script>
</head>
<body class="<%= currentLanguage === 'en' ? 'en' : '' %>">

    <%# شريط الإعلانات الترويجي %>
    <% if (store.showPromoBanner !== false) { %>
    <div class="promo-banner" id="promoBanner">
        <span>
            <i class="fas fa-truck"></i>
            <%= currentLanguage === 'en' ? (store.promoBannerTextEn || 'Free shipping over 300 SAR') : (store.promoBannerText || '🚀 شحن مجاني للطلبات فوق 300 ريال') %>
        </span>
        <button class="close-banner" onclick="document.getElementById('promoBanner').style.display='none'" aria-label="إغلاق">
            <i class="fas fa-times"></i>
        </button>
    </div>
    <% } %>

    <%# الهيدر الرئيسي %>
    <header class="main-header" id="mainHeader">
        <div class="container">
            <div class="header-content">
                
                <button class="mobile-menu-toggle" aria-label="القائمة">
                    <i class="fas fa-bars"></i>
                </button>
                
                <div class="logo-container">
                    <a href="/" class="logo-link" title="<%= store.storeName || 'متجر الرعدي أون لاين' %>">
                        <span style="font-size: 40px;">🦅</span>
                        <span class="store-name"><%= store.storeName || 'متجر الرعدي أون لاين' %></span>
                    </a>
                </div>
                
                <div class="search-container">
                    <form class="search-bar" action="/search" method="GET">
                        <input type="text" name="q" placeholder="<%= currentLanguage === 'en' ? 'Search...' : 'ابحث عن المنتجات...' %>" aria-label="البحث">
                        <button type="submit" aria-label="بحث"><i class="fas fa-search"></i></button>
                    </form>
                </div>
                
                <div class="header-actions">
                    
                    <a href="/switch-language/<%= currentLanguage === 'ar' ? 'en' : 'ar' %>" class="header-icon" title="<%= currentLanguage === 'ar' ? 'English' : 'العربية' %>">
                        <i class="fas fa-language"></i>
                    </a>
                    
                    <button class="header-icon" id="dark-mode-toggle" title="الوضع الليلي">
                        <i class="fas fa-moon"></i>
                    </button>
                    
                    <% if (user) { %>
                    <a href="/account/wishlist" class="header-icon" title="المفضلة">
                        <i class="fas fa-heart"></i>
                    </a>
                    <% } %>
                    
                    <a href="/cart" class="header-icon cart-icon" title="سلة التسوق" style="position: relative;">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="badge-count" id="cartBadge" style="<%= typeof cartCount !== 'undefined' && cartCount > 0 ? '' : 'display:none;' %>position:absolute;top:-5px;right:-8px;background:var(--secondary-color);color:white;font-size:11px;font-weight:bold;width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;border:2px solid var(--primary-color);">
                            <%= typeof cartCount !== 'undefined' ? cartCount : 0 %>
                        </span>
                    </a>
                    
                    <% if (user) { %>
                        <a href="/account" class="header-icon" title="حسابي">
                            <i class="fas fa-user-circle" style="font-size: 28px;"></i>
                        </a>
                        <% if (user.role === 'admin' || user.role === 'superadmin') { %>
                            <a href="/admin/dashboard" class="login-btn" style="background: var(--gold-color); color: var(--primary-color);">
                                <i class="fas fa-cog"></i> لوحة التحكم
                            </a>
                        <% } %>
                        <a href="/auth/logout" class="login-btn" style="background: var(--secondary-color);">
                            <i class="fas fa-sign-out-alt"></i> خروج
                        </a>
                    <% } else { %>
                        <a href="/auth/login" class="login-btn">
                            <i class="fas fa-user"></i> تسجيل الدخول
                        </a>
                    <% } %>
                </div>
            </div>
            
            <nav class="main-nav" id="mainNav">
                <ul>
                    <li><a href="/"><i class="fas fa-home"></i> الرئيسية</a></li>
                    <li><a href="/products"><i class="fas fa-th-large"></i> المنتجات</a></li>
                    <li><a href="/offers"><i class="fas fa-tags" style="color: var(--gold-color);"></i> العروض</a></li>
                    <li><a href="/contact"><i class="fas fa-envelope"></i> اتصل بنا</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main class="main-content">
        
        <% if (success_msg && success_msg.length > 0) { %>
            <div class="container">
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i>
                    <span><%= success_msg %></span>
                </div>
            </div>
        <% } %>
        
        <% if (error_msg && error_msg.length > 0) { %>
            <div class="container">
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i>
                    <span><%= error_msg %></span>
                </div>
            </div>
        <% } %>
