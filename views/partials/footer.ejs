<%# ============================================= %>
<%# متجر الرعدي أون لاين - alradi-online          %>
<%# تذييل الموقع الكامل والمطور مع الشات الذكي      %>
<%# ============================================= %>

    </main>
    <%# نهاية المحتوى الرئيسي %>

    <footer class="main-footer">
        <div class="container">
            <div class="footer-content">
                
                <%# عمود: عن المتجر %>
                <div class="footer-section">
                    <span style="font-size: 50px;">🦅</span>
                    <h3><%= store.storeName || 'متجر الرعدي أون لاين' %></h3>
                    <p class="footer-description">
                        <%= currentLanguage === 'en' ? 
                            (store.storeDescriptionEn || 'Your integrated destination for global online shopping') : 
                            (store.storeDescription || 'وجهتك المتكاملة للتسوق الإلكتروني العالمي - تجربة تسوق فائقة وآمنة') %>
                    </p>
                    
                    <div class="social-links">
                        <% if (store.socialMedia && store.socialMedia.facebook) { %>
                            <a href="<%= store.socialMedia.facebook %>" class="social-link" target="_blank" title="Facebook">
                                <i class="fab fa-facebook-f"></i>
                            </a>
                        <% } %>
                        <% if (store.socialMedia && store.socialMedia.twitter) { %>
                            <a href="<%= store.socialMedia.twitter %>" class="social-link" target="_blank" title="Twitter">
                                <i class="fab fa-twitter"></i>
                            </a>
                        <% } %>
                        <% if (store.socialMedia && store.socialMedia.instagram) { %>
                            <a href="<%= store.socialMedia.instagram %>" class="social-link" target="_blank" title="Instagram">
                                <i class="fab fa-instagram"></i>
                            </a>
                        <% } %>
                        <% if (store.whatsappNumber) { %>
                            <a href="https://wa.me/<%= store.whatsappNumber %>" class="social-link" target="_blank" title="WhatsApp">
                                <i class="fab fa-whatsapp"></i>
                            </a>
                        <% } %>
                    </div>
                </div>
                
                <%# عمود: روابط سريعة %>
                <div class="footer-section">
                    <h3><%= currentLanguage === 'en' ? 'Quick Links' : 'روابط سريعة' %></h3>
                    <ul class="footer-links">
                        <li><a href="/"><i class="fas fa-chevron-left"></i> الرئيسية</a></li>
                        <li><a href="/products"><i class="fas fa-chevron-left"></i> جميع المنتجات</a></li>
                        <li><a href="/offers"><i class="fas fa-chevron-left"></i> العروض والتخفيضات</a></li>
                        <li><a href="/about"><i class="fas fa-chevron-left"></i> من نحن</a></li>
                        <li><a href="/contact"><i class="fas fa-chevron-left"></i> اتصل بنا</a></li>
                        <li><a href="/track-order"><i class="fas fa-chevron-left"></i> تتبع الطلب</a></li>
                        <li><a href="/sitemap"><i class="fas fa-chevron-left"></i> خريطة الموقع</a></li>
                    </ul>
                </div>
                
                <%# عمود: السياسات %>
                <div class="footer-section">
                    <h3><%= currentLanguage === 'en' ? 'Policies' : 'السياسات' %></h3>
                    <ul class="footer-links">
                        <li><a href="/privacy-policy"><i class="fas fa-chevron-left"></i> سياسة الخصوصية</a></li>
                        <li><a href="/terms"><i class="fas fa-chevron-left"></i> الشروط والأحكام</a></li>
                        <li><a href="/shipping-policy"><i class="fas fa-chevron-left"></i> سياسة الشحن والتسليم</a></li>
                        <li><a href="/return-policy"><i class="fas fa-chevron-left"></i> سياسة الاستبدال والاسترجاع</a></li>
                    </ul>
                </div>
                
                <%# عمود: معلومات الاتصال %>
                <div class="footer-section">
                    <h3><%= currentLanguage === 'en' ? 'Contact Info' : 'معلومات الاتصال' %></h3>
                    <ul class="footer-links">
                        <% if (store.contactEmail) { %>
                            <li>
                                <a href="mailto:<%= store.contactEmail %>">
                                    <i class="fas fa-envelope"></i> <%= store.contactEmail %>
                                </a>
                            </li>
                        <% } %>
                        <% if (store.phoneNumber) { %>
                            <li>
                                <a href="tel:<%= store.phoneNumber %>">
                                    <i class="fas fa-phone"></i> <%= store.phoneNumber %>
                                </a>
                            </li>
                        <% } %>
                        <% if (store.whatsappNumber) { %>
                            <li>
                                <a href="https://wa.me/<%= store.whatsappNumber %>" target="_blank">
                                    <i class="fab fa-whatsapp"></i> <%= store.whatsappNumber %>
                                </a>
                            </li>
                        <% } %>
                        <% if (store.address) { %>
                            <li>
                                <i class="fas fa-map-marker-alt"></i> 
                                <%= store.address %>
                            </li>
                        <% } %>
                    </ul>
                    
                    <div style="margin-top: 15px;">
                        <p style="font-size: 13px; margin-bottom: 8px; color: rgba(255,255,255,0.6);">طرق الدفع</p>
                        <div style="display: flex; gap: 8px; flex-wrap: wrap; font-size: 24px;">
                            <i class="fab fa-cc-visa" style="color: #1a1f71;"></i>
                            <i class="fab fa-cc-mastercard" style="color: #eb001b;"></i>
                            <span style="background: white; color: #0066c1; padding: 2px 8px; border-radius: 4px; font-size: 12px; font-weight: bold;">مدى</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <%# حقوق الملكية %>
            <div class="footer-bottom">
                <p>
                    <%= currentLanguage === 'en' ? 
                        (store.copyrightTextEn || 'All Rights Reserved © 2026 Al-Radi Online Luxury Stores Group - Superior and Safe Shopping Experience.') : 
                        (store.copyrightText || 'جميع الحقوق محفوظة © 2026 لمجموعة متاجر الرعدي أونلاين الفاخرة - تجربة تسوق فائقة وآمنة.') %>
                </p>
            </div>
        </div>
    </footer>

    <%# زر العودة للأعلى %>
    <button class="back-to-top" id="backToTop" title="العودة للأعلى" onclick="window.scrollTo({top:0,behavior:'smooth'})">
        <i class="fas fa-arrow-up"></i>
    </button>

    <div id="toast-container"></div>

    <script>
        const storeSettings = {
            voiceGreetingEnabled: <%= store.voiceGreetingEnabled ? 'true' : 'false' %>,
            voiceInteractionsEnabled: <%= store.voiceInteractionsEnabled ? 'true' : 'false' %>,
            voiceGreetingFile: '<%= store.voiceGreetingFile || "/audio/welcome.mp3" %>'
        };
        const currentUserId = '<%= user ? user._id : "" %>';
        const currentUserName = '<%= user ? user.name : "" %>';
        const currentUserRole = '<%= user ? user.role : "visitor" %>';
    </script>
    
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/main.js"></script>
    
    <% if (store.voiceGreetingEnabled !== false) { %>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const greetingPlayed = sessionStorage.getItem('voiceGreetingPlayed');
            if (!greetingPlayed) {
                setTimeout(function() {
                    try {
                        const audio = new Audio(storeSettings.voiceGreetingFile);
                        audio.volume = 0.5;
                        audio.play().catch(function() {});
                        sessionStorage.setItem('voiceGreetingPlayed', 'true');
                    } catch(e) {}
                }, 2000);
            }
        });
    </script>
    <% } %>

<%# ========== نظام المحادثة الحية الفوري والذكي لمتجر الرعدي ========== %>
<% if (user && user.role !== 'admin') { %>
<style>
    .chat-widget-btn {
        position: fixed;
        bottom: 25px;
        right: 25px;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1a1a2e, #0f3460);
        color: #d4af37;
        border: 2px solid #d4af37;
        cursor: pointer;
        font-size: 26px;
        box-shadow: 0 8px 25px rgba(26,26,46,0.4);
        z-index: 999;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .chat-widget-btn:hover {
        transform: scale(1.1) rotate(5deg);
        box-shadow: 0 12px 30px rgba(212,175,55,0.4);
    }
    .chat-widget-box {
        position: fixed;
        bottom: 100px;
        right: 25px;
        width: 360px;
        height: 480px;
        background: #ffffff;
        border-radius: 24px;
        box-shadow: 0 15px 50px rgba(0,0,0,0.15), 0 0 0 1px rgba(212,175,55,0.2);
        z-index: 998;
        display: none;
        flex-direction: column;
        overflow: hidden;
        border: 1px solid #ede8e0;
    }
    .chat-widget-header {
        background: linear-gradient(135deg, #1a1a2e, #0f3460);
        color: #d4af37;
        padding: 15px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid #d4af37;
    }
    .chat-widget-header h4 { margin: 0; font-size: 15px; font-weight: 700; display: flex; align-items: center; gap: 8px;}
    .chat-widget-header button { background: none; border: none; color: #d4af37; font-size: 18px; cursor: pointer; }
    
    .chat-widget-messages {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        background: #fdfcf9;
    }
    .chat-widget-messages .message {
        padding: 12px 16px;
        border-radius: 16px;
        max-width: 80%;
        font-size: 13px;
        line-height: 1.6;
        position: relative;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
    }
    
    /* فقاعة العميل (أنت): يسار الشاشة بلون كحلي فخم */
    .chat-widget-messages .message.sent {
        background: linear-gradient(135deg, #1a1a2e, #0f3460);
        color: white;
        align-self: flex-start;
        border-top-left-radius: 4px;
    }
    
    /* فقاعة الإدارة والرد التلقائي: يمين الشاشة بلون ذهبي هادئ */
    .chat-widget-messages .message.received {
        background: linear-gradient(135deg, #fdf8e9, #f5eacb);
        color: #4a3b1a;
        align-self: flex-end;
        border-top-right-radius: 4px;
        border: 1px solid rgba(212,175,55,0.3);
    }
    
    .chat-widget-messages .msg-time {
        display: block;
        font-size: 10px;
        margin-top: 5px;
        opacity: 0.6;
    }
    .chat-widget-messages .message.sent .msg-time { text-align: left; }
    .chat-widget-messages .message.received .msg-time { text-align: right; }

    .chat-widget-form {
        padding: 12px 15px;
        border-top: 1px solid #f0ece6;
        display: flex;
        gap: 10px;
        background: #fff;
        align-items: center;
    }
    .chat-widget-form input {
        flex: 1;
        padding: 12px 16px;
        border: 1px solid #e8e0d5;
        border-radius: 30px;
        font-family: inherit;
        font-size: 13px;
        outline: none;
        background: #fbfbfa;
    }
    .chat-widget-form input:focus {
        border-color: #d4af37;
        background: #fff;
    }
    .chat-widget-form button {
        background: linear-gradient(135deg, #1a1a2e, #0f3460);
        color: #d4af37;
        border: 1px solid #d4af37;
        width: 42px;
        height: 42px;
        border-radius: 50%;
        cursor: pointer;
        font-size: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .chat-widget-form button:hover {
        background: #d4af37;
        color: #1a1a2e;
    }
    @media (max-width: 500px) {
        .chat-widget-box { width: 92vw; right: 4vw; bottom: 95px; height: 70vh; }
    }
</style>

<button class="chat-widget-btn" id="chatWidgetBtn" title="الدعم المباشر للمجلس الملكي">
    <i class="fas fa-comments"></i>
</button>

<div class="chat-widget-box" id="chatWidgetBox">
    <div class="chat-widget-header">
        <h4><i class="fas fa-headset"></i> المحادثة الفورية الفاخرة</h4>
        <button onclick="document.getElementById('chatWidgetBox').style.display='none'">
            <i class="fas fa-times"></i>
        </button>
    </div>
    <div class="chat-widget-messages" id="chatWidgetMessages">
        <div class="message received">
            <strong>فريق الدعم الملكي:</strong><br>
            مرحباً بك في مجموعة متاجر الرعدي أونلاين. يسعدنا ويشرفنا خدمتك، كيف يمكننا مساندتك اليوم؟
            <span class="msg-time"><%= new Date().toLocaleTimeString('ar-SA', {hour: '2-digit', minute:'2-digit'}) %></span>
        </div>
    </div>
    <form class="chat-widget-form" id="chatWidgetForm">
        <input type="text" id="chatWidgetInput" placeholder="اكتب استفسارك الفاخر هنا..." autocomplete="off" required>
        <button type="submit"><i class="fas fa-paper-plane"></i></button>
    </form>
</div>

<script>
let autoReplyTimer = null; 

document.getElementById('chatWidgetBtn').addEventListener('click', function() {
    const box = document.getElementById('chatWidgetBox');
    box.style.display = box.style.display === 'flex' ? 'none' : 'flex';
    if(box.style.display === 'flex') {
        const messagesDiv = document.getElementById('chatWidgetMessages');
        messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }
});

document.getElementById('chatWidgetForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const input = document.getElementById('chatWidgetInput');
    const msg = input.value.trim();
    if (msg) {
        const messagesDiv = document.getElementById('chatWidgetMessages');
        const currentTime = new Date().toLocaleTimeString('ar-SA', {hour: '2-digit', minute:'2-digit'});
        
        // عرض رسالة العميل في جهة اليسار باللون الكحلي
        messagesDiv.innerHTML += `
            <div class="message sent">
                <strong>أنت:</strong><br>${msg}
                <span class="msg-time">${currentTime}</span>
            </div>
        `;
        messagesDiv.scrollTop = messagesDiv.scrollHeight;
        input.value = '';
        
        // إرسال البيانات الحي عبر السوكيت
        if (typeof socket !== 'undefined' && socket) {
            socket.emit('send-message', { 
                senderId: currentUserId,
                senderName: currentUserName,
                content: msg,
                isAdmin: false
            });
        }

        // الرد التلقائي الذكي عند غياب رد المدير لـ 7 ثوانٍ
        if(autoReplyTimer) clearTimeout(autoReplyTimer);
        autoReplyTimer = setTimeout(function() {
            messagesDiv.innerHTML += `
                <div class="message received" style="border-right: 4px solid #d4af37;">
                    <strong>🤖 الرد التلقائي لآل الرعدي:</strong><br>
                    عذراً على التأخر البسيط يا فندم، انشغالنا الحالي هو لتوفير أعلى جودة لكم. تم إشعار الإدارة العليا والمدير الفني برسالتك وسيتدخل أحد مستشارينا لمحادثتك حياً في أقرب دقيقة!
                    <span class="msg-time">${new Date().toLocaleTimeString('ar-SA', {hour: '2-digit', minute:'2-digit'})}</span>
                </div>
            `;
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        }, 7000); 
    }
});

// استقبال ردود المدير وعرضها فوراً في جهة اليمين بالذهبي
if (typeof socket !== 'undefined' && socket) {
    socket.on('receive-message', function(data) {
        if(autoReplyTimer) clearTimeout(autoReplyTimer);
        
        if (data.isAdmin) {
            const messagesDiv = document.getElementById('chatWidgetMessages');
            const currentTime = new Date().toLocaleTimeString('ar-SA', {hour: '2-digit', minute:'2-digit'});
            messagesDiv.innerHTML += `
                <div class="message received">
                    <strong>الإدارة العليا:</strong><br>${data.content}
                    <span class="msg-time">${currentTime}</span>
                </div>
            `;
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        }
    });
}
</script>
<% } %>

</body>
</html>
