<%# ============================================= %>
<%# متجر الرعدي أون لاين - alradi-online          %>
<%# بطاقة المنتج الموحدة - النسخة النهائية الكاملة     %>
<%# ============================================= %>

<div class="product-card animate-fadeIn">
    
    <div class="product-image-container">
        <a href="/products/<%= product.slug || product._id %>">
            <img src="<%= product.images && product.images.length > 0 ? product.images[0].url : '/images/default-product.png' %>" 
                 alt="<%= product.name %>"
                 loading="lazy"
                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
            <div style="display: none; width: 100%; height: 100%; background: #f0f0f0; align-items: center; justify-content: center; font-size: 50px;">📦</div>
        </a>
        
        <div class="product-badges">
            <% if (product.isOnSale) { %>
                <span class="badge badge-sale"><i class="fas fa-tag"></i> تخفيض</span>
            <% } %>
            <% if (product.isNewArrival) { %>
                <span class="badge badge-new"><i class="fas fa-bolt"></i> جديد</span>
            <% } %>
            <% if (product.isFeatured) { %>
                <span class="badge badge-featured"><i class="fas fa-star"></i> مميز</span>
            <% } %>
            <% if (product.stockStatus === 'out_of_stock') { %>
                <span class="badge badge-out-of-stock"><i class="fas fa-times-circle"></i> نفد</span>
            <% } %>
            <% if (product.stockStatus === 'low_stock' && product.stock > 0) { %>
                <span class="badge" style="background: var(--warning-color); color: white; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: bold;">
                    <i class="fas fa-exclamation-circle"></i> تبقت <%= product.stock %> فقط
                </span>
            <% } %>
        </div>
        
        <div class="product-actions">
            <button class="action-btn wishlist-btn" 
                    data-product-id="<%= product._id %>"
                    onclick="toggleWishlist('<%= product._id %>')"
                    title="أضف للمفضلة">
                <i class="far fa-heart"></i>
            </button>
            <a href="/products/<%= product.slug || product._id %>" class="action-btn quick-view-btn" title="عرض التفاصيل">
                <i class="fas fa-eye"></i>
            </a>
        </div>
    </div>
    
    <div class="product-info">
        <% if (product.category && product.category.name) { %>
            <span class="product-category">
                <i class="fas fa-folder"></i> 
                <%= product.category.name %>
            </span>
        <% } %>
        
        <h3 class="product-name">
            <a href="/products/<%= product.slug || product._id %>">
                <%= product.name %>
            </a>
        </h3>
        
        <div class="product-rating">
            <% if (product.rating && product.rating.average > 0) { %>
                <div class="stars">
                    <% for (var i = 1; i <= 5; i++) { %>
                        <% if (i <= Math.floor(product.rating.average)) { %>
                            <i class="fas fa-star"></i>
                        <% } else if (i - 0.5 <= product.rating.average) { %>
                            <i class="fas fa-star-half-alt"></i>
                        <% } else { %>
                            <i class="far fa-star"></i>
                        <% } %>
                    <% } %>
                </div>
                <span class="rating-count">(<%= product.rating.count || 0 %>)</span>
            <% } else { %>
                <div class="stars">
                    <i class="far fa-star" style="color: #ddd;"></i>
                    <i class="far fa-star" style="color: #ddd;"></i>
                    <i class="far fa-star" style="color: #ddd;"></i>
                    <i class="far fa-star" style="color: #ddd;"></i>
                    <i class="far fa-star" style="color: #ddd;"></i>
                </div>
                <span class="rating-count" style="font-size: 11px; color: var(--text-muted);">جديد</span>
            <% } %>
        </div>
        
        <div class="product-price-container">
            <% if (product.isOnSale && product.comparePrice) { %>
                <span class="current-price"><%= product.price %> ر.س</span>
                <span class="old-price"><%= product.comparePrice %> ر.س</span>
                <span class="discount-percentage">-<%= Math.round((1 - product.price / product.comparePrice) * 100) %>%</span>
            <% } else { %>
                <span class="current-price"><%= product.price %> ر.س</span>
            <% } %>
        </div>
        
        <div class="stock-status <%= product.stockStatus === 'out_of_stock' ? 'out-of-stock' : (product.stockStatus === 'low_stock' ? 'low-stock' : 'in-stock') %>">
            <% if (product.stockStatus === 'in_stock') { %>
                <i class="fas fa-check-circle"></i> متوفر<% if (product.stock && product.stock > 0) { %>: <%= product.stock %> قطعة<% } %>
            <% } else if (product.stockStatus === 'low_stock') { %>
                <i class="fas fa-exclamation-circle"></i> تبقت <%= product.stock %> قطعة فقط
            <% } else { %>
                <i class="fas fa-times-circle"></i> نفد من المخزون
            <% } %>
        </div>
        
        <% if (product.stockStatus !== 'out_of_stock') { %>
            <a href="/cart/add?productId=<%= product._id %>&quantity=1" class="add-to-cart-btn" style="text-decoration: none; width:100%; display: flex; align-items: center; justify-content: center; gap: 8px; border: none; cursor: pointer; font-family: inherit; font-size: 15px; font-weight: 600; padding: 12px; border-radius: 10px;">
                <i class="fas fa-shopping-cart"></i> أضف إلى السلة
            </a>
        <% } else { %>
            <button class="add-to-cart-btn" disabled style="background: #999; cursor: not-allowed; width: 100%;">
                <i class="fas fa-times-circle"></i> نفد من المخزون
            </button>
        <% } %>
    </div>
</div>
