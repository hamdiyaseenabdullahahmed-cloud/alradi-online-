<%# ============================================= %>
<%# متجر الرعدي أون لاين - alradi-online          %>
<%# بطاقة المنتج - النسخة الذهبية النهائية            %>
<%# ============================================= %>

<div class="product-card glass-card" style="
    background: rgba(255,255,255,0.7); backdrop-filter: blur(10px);
    border: 1px solid rgba(255,215,0,0.3); border-radius: 20px; overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.1); transition: all 0.4s ease;
    position: relative; display: flex; flex-direction: column; height: 100%;
">
    <%# تأثير Shine Flare %>
    <div class="shine-flare" style="
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        background: radial-gradient(circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(255,215,0,0.2) 0%, transparent 70%);
        pointer-events: none; z-index: 1; opacity: 0; transition: opacity 0.3s;
    "></div>

    <div style="position: relative; overflow: hidden; height: 220px; background: #f8f9fb; z-index: 0;">
        <a href="/products/<%= product.slug || product._id %>">
            <img src="<%= (product.images && product.images.length > 0 && product.images[0].url) ? product.images[0].url : '/images/default-product.png' %>" 
                 alt="<%= product.name %>" loading="lazy"
                 style="width:100%; height:100%; object-fit:cover; transition: transform 0.5s ease;"
                 onerror="this.onerror=null; this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22200%22><rect fill=%22%23f0f0f0%22 width=%22200%22 height=%22200%22/><text x=%22100%22 y=%22110%22 text-anchor=%22middle%22 font-size=%2260%22>📦</text></svg>';">
        </a>
        
        <div style="position:absolute; top:12px; right:12px; display:flex; flex-direction:column; gap:5px; z-index:2;">
            <% if (product.isOnSale) { %><span style="background:#e94560; color:white; padding:4px 10px; border-radius:15px; font-size:11px; font-weight:bold;"><i class="fas fa-tag"></i> تخفيض</span><% } %>
            <% if (product.isFeatured) { %><span style="background:gold; color:#333; padding:4px 10px; border-radius:15px; font-size:11px; font-weight:bold;"><i class="fas fa-star"></i> مميز</span><% } %>
            <% if (product.isNewArrival) { %><span style="background:#0f3460; color:white; padding:4px 10px; border-radius:15px; font-size:11px; font-weight:bold;"><i class="fas fa-bolt"></i> جديد</span><% } %>
        </div>
    </div>

    <div style="padding:16px; flex:1; display:flex; flex-direction:column; text-align:right; direction:rtl; z-index:2; position:relative;">
        <% if (product.category && product.category.name) { %>
            <span style="font-size:11px; color:#888; margin-bottom:4px; display:block;"><i class="fas fa-folder" style="color:#ffd700;"></i> <%= product.category.name %></span>
        <% } %>
        <h3 style="font-size:15px; font-weight:700; margin:0 0 8px 0; line-height:1.4;">
            <a href="/products/<%= product.slug || product._id %>" style="color:#1a1a2e; text-decoration:none;"><%= product.name %></a>
        </h3>
        <div style="display:flex; align-items:center; gap:4px; margin-bottom:8px;">
            <% var avg = (product.rating && product.rating.average) ? product.rating.average : 0; %>
            <% for (var i = 1; i <= 5; i++) { %>
                <i class="fas fa-star" style="font-size:11px; color:<%= i <= Math.floor(avg) ? '#ffd700' : '#ddd' %>;"></i>
            <% } %>
            <span style="font-size:11px; color:#999;">(<%= (product.rating && product.rating.count) ? product.rating.count : 0 %>)</span>
        </div>
        <div style="margin-bottom:10px; display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
            <% if (product.isOnSale && product.comparePrice && product.comparePrice > product.price) { %>
                <span style="font-size:20px; font-weight:900; color:#e94560;"><%= product.price %> ر.س</span>
                <span style="font-size:13px; color:#bbb; text-decoration:line-through;"><%= product.comparePrice %> ر.س</span>
                <span style="background:#ffe0e0; color:#e94560; padding:2px 8px; border-radius:10px; font-size:11px; font-weight:bold;">-<%= Math.round((1 - product.price / product.comparePrice) * 100) %>%</span>
            <% } else { %>
                <span style="font-size:20px; font-weight:900; color:#1a1a2e;"><%= product.price %> ر.س</span>
            <% } %>
        </div>
        
        <%# تم تصحيح هذا القسم بالكامل لتجنب أخطاء EJS %>
        <div style="font-size:12px; margin-bottom:12px;">
            <% if (product.stock > 5) { %>
                <span style="color:#28a745;"><i class="fas fa-check-circle"></i> متوفر</span>
            <% } %>
            <% if (product.stock > 0 && product.stock <= 5) { %>
                <span style="color:#ff6b35;"><i class="fas fa-exclamation-circle"></i> تبقت <%= product.stock %> فقط</span>
            <% } %>
            <% if (product.stock <= 0) { %>
                <span style="color:#dc3545;"><i class="fas fa-times-circle"></i> نفد</span>
            <% } %>
        </div>

        <% if (product.stock > 0) { %>
            <button data-id="<%= product._id %>" onclick="directAddToCart(this)" style="
                display:block; width:100%; padding:13px; margin-top:auto;
                background: linear-gradient(135deg, #1a1a2e, #0f3460);
                color:white; text-align:center; border-radius:30px;
                border:none; font-weight:700; font-size:15px;
                transition: all 0.3s ease; cursor:pointer;
            " onmouseover="this.style.background='linear-gradient(135deg, #ffd700, #b89700)'; this.style.color='#111';" 
               onmouseout="this.style.background='linear-gradient(135deg, #1a1a2e, #0f3460)'; this.style.color='white';">
                <i class="fas fa-shopping-cart"></i> أضف إلى السلة
            </button>
        <% } else { %>
            <button disabled style="width:100%; padding:13px; margin-top:auto; background:#ddd; color:#999; border:none; border-radius:30px; font-weight:700; font-size:15px; cursor:not-allowed;">
                <i class="fas fa-times-circle"></i> نفد من المخزون
            </button>
        <% } %>
    </div>
</div>

<script>
// دالة الإضافة المباشرة (AJAX مع Fallback)
async function directAddToCart(button) {
    const pId = button.getAttribute('data-id');
    if(!pId) return;
    
    const originalText = button.innerHTML;
    button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الحفظ...';
    button.disabled = true;

    try {
        const res = await fetch(`/cart/add?productId=${pId}&quantity=1`);
        button.innerHTML = '✅ تمت الإضافة!';
        button.style.background = '#28a745';
        button.style.color = 'white';
        
        // تحديث عدادات السلة
        const badges = document.querySelectorAll('.cart-badge, .cart-count, #cart-count');
        badges.forEach(b => { b.innerText = parseInt(b.innerText || 0) + 1; });

        setTimeout(() => {
            button.innerHTML = originalText;
            button.style.background = 'linear-gradient(135deg, #1a1a2e, #0f3460)';
            button.disabled = false;
        }, 1500);
    } catch (e) {
        window.location.href = `/cart/add?productId=${pId}&quantity=1`;
    }
}

// تأثير Shine Flare عند حركة الماوس
document.querySelectorAll('.glass-card').forEach(card => {
    card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        card.style.setProperty('--mouse-x', `${x}px`);
        card.style.setProperty('--mouse-y', `${y}px`);
        card.querySelector('.shine-flare').style.opacity = '1';
    });
    card.addEventListener('mouseleave', () => {
        card.querySelector('.shine-flare').style.opacity = '0';
    });
});
</script>
