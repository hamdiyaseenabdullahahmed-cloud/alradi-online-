<%# ============================================= %>
<%# متجر الرعدي أون لاين - alradi-online          %>
<%# بطاقة المنتج الموحدة والمهندسة - خالية من التكرار %>
<%# ============================================= %>

<div class="product-card complex-card animate-fadeIn" data-product-id="<%= product._id %>" style="
    background: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 15px;
    overflow: hidden;
    position: relative;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
">
    
    <div class="product-image-container" style="position: relative; overflow: hidden; background: #f9f9f9;">
        <a href="/products/<%= product.slug || product._id %>">
            <%# معالجة ذكية لمسار الصورة لمنع خطأ الـ 404 وتأمين الرفع %>
            <% 
                var imageUrl = '/images/default-product.png';
                if (product.images && product.images.length > 0) {
                    imageUrl = product.images[0].url ? product.images[0].url : product.images[0];
                }
            %>
            <img src="<%= imageUrl %>" 
                 alt="<%= product.name %>"
                 loading="lazy"
                 style="width: 100%; height: 250px; object-fit: cover; transition: transform 0.5s ease;"
                 onerror="this.src='/images/default-product.png';">
        </a>
        
        <div class="product-badges" style="position: absolute; top: 10px; right: 10px; display: flex; flex-direction: column; gap: 5px; z-index: 2;">
            <% if (product.isOnSale) { %><span class="badge badge-sale" style="background: #e94560; color: white; padding: 4px 8px; font-size: 11px; font-weight: bold; border-radius: 4px;"><i class="fas fa-tag"></i> تخفيض</span><% } %>
            <% if (product.isNewArrival) { %><span class="badge badge-new" style="background: #0f3460; color: white; padding: 4px 8px; font-size: 11px; font-weight: bold; border-radius: 4px;"><i class="fas fa-bolt"></i> جديد</span><% } %>
            <% if (product.isFeatured) { %><span class="badge badge-featured" style="background: #ffd700; color: #111; padding: 4px 8px; font-size: 11px; font-weight: bold; border-radius: 4px;"><i class="fas fa-star"></i> مميز</span><% } %>
            <% if (product.stockStatus === 'out_of_stock' || product.stock <= 0) { %><span class="badge badge-out-of-stock" style="background: #6c757d; color: white; padding: 4px 8px; font-size: 11px; font-weight: bold; border-radius: 4px;"><i class="fas fa-times-circle"></i> نفد</span><% } %>
        </div>
        
        <div class="product-actions">
            <button class="action-btn wishlist-btn" data-product-id="<%= product._id %>" onclick="if(typeof toggleWishlist === 'function') toggleWishlist('<%= product._id %>'); else alert('تمت الإضافة للمفضلة')" title="أضف للمفضلة">
                <i class="far fa-heart"></i>
            </button>
        </div>
    </div>
    
    <div class="product-info" style="padding: 15px; direction: rtl; text-align: right;">
        <% if (product.category && product.category.name) { %>
            <span class="product-category" style="font-size: 12px; color: #888; display: block; margin-bottom: 5px;">
                <i class="fas fa-folder" style="color: #ffd700;"></i> <%= product.category.name %>
            </span>
        <% } %>
        
        <h3 class="product-name" style="font-size: 16px; font-weight: 700; margin: 0 0 10px 0; line-height: 1.4;">
            <a href="/products/<%= product.slug || product._id %>" style="color: #1a1a2e; text-decoration: none; transition: color 0.2s;"><%= product.name %></a>
        </h3>
        
        <div class="product-rating" style="margin-bottom: 10px; display: flex; align-items: center; gap: 5px;">
            <% if (product.rating && product.rating.average > 0) { %>
                <div class="stars">
                    <% for (var i = 1; i <= 5; i++) { %>
                        <i class="fas fa-star" style="color: <%= i <= product.rating.average ? '#ffd700' : '#ddd' %>; font-size: 12px;"></i>
                    <% } %>
                </div>
                <span class="rating-count" style="font-size: 11px; color: #aaa;">(<%= product.rating.count || 0 %>)</span>
            <% } %>
        </div>
        
        <div class="product-price-container" style="margin-bottom: 12px; display: flex; align-items: center; gap: 10px;">
            <% if (product.isOnSale && product.comparePrice) { %>
                <span class="current-price" style="font-size: 18px; font-weight: 800; color: #0f3460;"><%= product.price %> <%= typeof currencySymbol !== 'undefined' ? currencySymbol : 'ر.س' %></span>
                <span class="old-price" style="font-size: 14px; color: #999; text-decoration: line-through;"><%= product.comparePrice %> ر.س</span>
            <% } else { %>
                <span class="current-price" style="font-size: 18px; font-weight: 800; color: #0f3460;"><%= product.price %> <%= typeof currencySymbol !== 'undefined' ? currencySymbol : 'ر.س' %></span>
            <% } %>
        </div>
        
        <div class="stock-status" style="font-size: 13px; margin-bottom: 15px;">
            <% if (product.stockStatus === 'in_stock' && product.stock > 0) { %>
                <span style="color: #28a745;"><i class="fas fa-check-circle"></i> متوفر في المخزون</span>
            <% } else if (product.stockStatus === 'low_stock' || (product.stock > 0 && product.stock <= 3)) { %>
                <span style="color: #ffc107;"><i class="fas fa-exclamation-circle"></i> متبقي <%= product.stock %> قطع فقط!</span>
            <% } else { %>
                <span style="color: #dc3545;"><i class="fas fa-times-circle"></i> غير متوفر حالياً</span>
            <% } %>
        </div>
        
        <% if (product.stock > 0 && product.stockStatus !== 'out_of_stock') { %>
            <%# استدعاء دالة addToCart الموحدة الموجودة في ملف الـ index الرئيسي لمنع التكرار %>
            <button class="add-to-cart-btn" data-id="<%= product._id %>" onclick="addToCart(this)" style="
                width: 100%;
                padding: 12px;
                background: linear-gradient(135deg, #1a1a2e, #0f3460);
                color: white;
                border: none;
                border-radius: 25px;
                font-size: 15px;
                font-weight: 700;
                cursor: pointer;
                transition: all 0.3s ease;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                box-shadow: 0 4px 6px rgba(15, 52, 96, 0.2);
            " onmouseover="this.style.background='linear-gradient(135deg, #ffd700, #b89700)'; this.style.color='#111'; this.style.transform='translateY(-2px)';" 
               onmouseout="this.style.background='linear-gradient(135deg, #1a1a2e, #0f3460)'; this.style.color='white'; this.style.transform='translateY(0)';">
                <i class="fas fa-shopping-cart"></i> شراء الآن
            </button>
        <% } else { %>
            <button disabled style="
                width: 100%; 
                padding: 12px; 
                background: #e0e0e0; 
                color: #a0a0a0; 
                border: none; 
                border-radius: 25px; 
                font-size: 15px; 
                font-weight: 700;
                cursor: not-allowed;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
            ">
                <i class="fas fa-times-circle"></i> نفد من المخزون
            </button>
        <% } %>
    </div>
</div>
