<%- include('partials/header') %>

<div class="container">
    <h1 style="font-size: 28px; font-weight: 800; color: var(--primary-color); margin-bottom: 30px;">
        <i class="fas fa-tags" style="color: var(--gold-color); margin-left: 10px;"></i>
        العروض والتخفيضات
    </h1>
    
    <% if (products && products.length > 0) { %>
        <div class="products-grid cols-4">
            <% products.forEach(function(product) { %>
                <%- include('partials/product-card', { product: product }) %>
            <% }); %>
        </div>
    <% } else { %>
        <div style="text-align: center; padding: 80px 20px; background: white; border-radius: 15px;">
            <div style="font-size: 80px; color: var(--text-muted); margin-bottom: 20px;">🏷️</div>
            <h3>لا توجد عروض حالياً</h3>
            <a href="/products" class="btn btn-primary btn-lg">تصفح المنتجات</a>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>
